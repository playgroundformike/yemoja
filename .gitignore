cat << 'EOF' > .gitignore
# Terraform
.terraform/
*.tfstate
*.tfstate.backup
*.tfplan
.terraform.lock.hcl

# Terragrunt
**/.terragrunt-cache/

# AWS
.aws/
*.pem

# SSH keys
*.key
wsl_key
wsl_key.pub
id_rsa
id_ed25519

# Secrets / env
.env
.env.*
*.tfvars
!example.tfvars

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Python (for your AppSec lab / Lambda projects)
__pycache__/
*.pyc
.venv/
venv/

# Node
node_modules/

# Logs
*.log
crash.log
EOF.terraform/
*.tfstate
*.tfstate.backup
.terraform.lock.hcl
**/.terragrunt-cache/
